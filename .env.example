# ───── Google APIs ─────
GOOGLE_PAGESPEED_API_KEY=

# ───── Google Search Console (OAuth2) ─────
# Create OAuth credentials in Google Cloud Console and generate a refresh
# token with the https://www.googleapis.com/auth/webmasters.readonly scope.
# Without these, the dashboard falls back to mock GSC data.
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# ───── FilaHive (Shopify) ─────
FILAHIVE_SHOPIFY_DOMAIN=filahive.myshopify.com
FILAHIVE_SHOPIFY_TOKEN=

# ───── APLUS Property Care (Google Ads) ─────
APLUS_GOOGLE_ADS_CID=106-780-6098

# ───── Vercel KV (for Settings UI) ─────
KV_REST_API_URL=                        # auto-set when you add KV in Vercel
KV_REST_API_TOKEN=                      # auto-set when you add KV in Vercel

# ───── App ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000
